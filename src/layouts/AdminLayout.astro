---
<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Administration</title>
  </head>
  <body class="min-h-screen bg-gray-100">

    <!-- Header -->
    <header class="bg-indigo-600 text-white px-4 py-3 flex items-center justify-between sticky top-0 z-40 shadow-md">
      <h1 class="font-semibold text-base">{title}</h1>
      <div class="flex items-center gap-3">
        <slot name="header-actions" />
        <form method="post" action="/api/admin/logout">
          <button type="submit" class="text-indigo-200 hover:text-white text-sm transition-colors">
            Déconnexion
          </button>
        </form>
      </div>
    </header>

    <!-- Desktop top nav (hidden on mobile) -->
    <nav class="hidden md:flex bg-indigo-700 px-4 gap-0">
      {nav.map(item => (
        <a
          href={item.href}
          class:list={[
            'flex items-center gap-2 px-4 py-2.5 text-sm font-medium transition-colors',
            active === item.key
              ? 'text-white border-b-2 border-white bg-indigo-800'
              : 'text-indigo-200 hover:text-white hover:bg-indigo-800',
          ]}
        >
          <span set:html={item.icon} />
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Page content -->
    <main class="pb-20 md:pb-0">
      <slot />
    </main>

    <!-- Mobile bottom tab nav -->
    <nav class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 flex md:hidden z-40">
      {nav.map(item => (
        <a
          href={item.href}
          class:list={[
            'flex-1 flex flex-col items-center justify-center py-2 gap-0.5 transition-colors',
            active === item.key
              ? 'text-indigo-600'
              : 'text-gray-400 hover:text-gray-600',
          ]}
        >
          <span set:html={item.icon} />
          <span class="text-[9px] leading-tight font-medium text-center">{item.label}</span>
        </a>
      ))}
    </nav>

  </body>
</html>
