---
import type { ScheduleSlot } from '../lib/db/slots';
interface Props {
  slots: ScheduleSlot[];
  remainingCount: number;
}
const { slots, remainingCount } = Astro.props;
---
<div class="space-y-1">
  <div class="flex items-center gap-2 mb-5">
    <span class="text-sm text-gray-600">Rendez-vous restants :</span>
    <span id="remaining-count" class="text-sm font-bold text-indigo-700 bg-indigo-100 px-3 py-0.5 rounded-full">
      {remainingCount}
    </span>
  </div>

  {slots.length === 0 ? (
    <p class="text-sm text-gray-400">Aucun créneau configuré pour aujourd'hui.</p>
  ) : (
    <div class="divide-y divide-gray-100 border border-gray-200 rounded-xl overflow-hidden shadow-sm">
      {slots.map(slot => (
        <div
          data-slot-id={slot.id}
          class:list={[
            'flex items-center gap-3 px-4 py-3',
            slot.is_booked ? 'bg-blue-50' : 'bg-white',
          ]}
        >
          <span class="text-sm font-mono text-gray-400 w-24 shrink-0">
            {slot.start_time}–{slot.end_time}
          </span>
          {slot.is_booked ? (
            <span class="slot-name text-sm font-semibold text-blue-800 flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-blue-500 shrink-0"></span>
              {slot.participant_name}
            </span>
          ) : (
            <span class="slot-name text-sm text-emerald-600 font-medium">Disponible</span>
          )}
        </div>
      ))}
    </div>
  )}
</div>
