---
interface Props {
  id: string;
  name: string;
  specialty: string;
  availableSlotCount: number;
  fullyBooked: boolean;
}
const { id, name, specialty, availableSlotCount, fullyBooked } = Astro.props;
---
<div class="practitioner-card bg-white rounded-xl border border-gray-200 p-4 shadow-sm" data-id={id}>
  <div class="flex items-start justify-between gap-3">
    <div>
      <h2 class="font-semibold text-gray-900">{name}</h2>
      <p class="text-sm text-gray-500">{specialty}</p>
    </div>
    {fullyBooked ? (
      <span class="shrink-0 text-xs font-semibold bg-red-50 text-red-600 px-2.5 py-1 rounded-full border border-red-100">
        Complet
      </span>
    ) : (
      <span class="slot-count shrink-0 text-xs font-semibold bg-emerald-50 text-emerald-700 px-2.5 py-1 rounded-full border border-emerald-100">
        {availableSlotCount} créneau{availableSlotCount > 1 ? 'x' : ''} disponible{availableSlotCount > 1 ? 's' : ''}
      </span>
    )}
  </div>
  {!fullyBooked && (
    <button
      class="book-btn mt-3 w-full bg-indigo-600 text-white text-sm py-2.5 rounded-xl hover:bg-indigo-700 font-semibold transition-colors"
      data-practitioner-id={id}
      data-practitioner-name={name}
    >
      Réserver
    </button>
  )}
</div>
