---
import type { PractitionerSchedule } from '../lib/db/slots';
interface Props {
  schedules: PractitionerSchedule[];
}
const { schedules } = Astro.props;
---
{schedules.length === 0 ? (
  <p class="text-sm text-gray-400 py-8 text-center">Aucun praticien·ne configuré·e.</p>
) : (
  <div class="overflow-x-auto">
    <div class="inline-flex gap-3 min-w-full pb-2">
      {schedules.map(p => (
        <div
          data-practitioner-id={p.practitionerId}
          data-fully-booked={p.fullyBooked ? 'true' : 'false'}
          class="bg-white rounded-xl border border-gray-200 overflow-hidden w-52 shrink-0 shadow-sm"
        >
          <div class="col-header px-3 py-2.5 bg-indigo-50 border-b border-indigo-100 flex items-start justify-between gap-2">
            <div class="min-w-0">
              <p class="text-sm font-semibold text-indigo-900 truncate">{p.practitionerName}</p>
              <p class="text-xs text-indigo-500 truncate">{p.specialty}</p>
            </div>
            {p.fullyBooked && (
              <span class="fully-booked-badge text-xs font-semibold text-red-600 bg-red-100 px-2 py-0.5 rounded-full shrink-0">Complet</span>
            )}
          </div>
          <div class="divide-y divide-gray-100">
            {p.slots.map(slot => (
              <div
                data-slot-id={slot.id}
                class:list={[
                  'flex items-center gap-2 px-3 py-2 group',
                  slot.is_booked ? 'bg-blue-50' : 'bg-white',
                ]}
              >
                <span class="text-xs font-mono text-gray-400 w-20 shrink-0">{slot.start_time}–{slot.end_time}</span>
                <span class:list={[
                  'slot-name text-xs truncate font-medium flex-1',
                  slot.is_booked ? 'text-blue-800' : 'text-emerald-600',
                ]}>
                  {slot.is_booked ? slot.participant_name : 'Libre'}
                </span>
                {!slot.is_booked && (
                  <button
                    class="delete-slot-btn opacity-0 group-hover:opacity-100 text-gray-300 hover:text-red-500 transition-all text-xs leading-none shrink-0 px-0.5"
                    data-slot-id={slot.id}
                    title="Supprimer ce créneau"
                  >
                    ✕
                  </button>
                )}
              </div>
            ))}
            {p.slots.length === 0 && (
              <p class="px-3 py-3 text-xs text-gray-400">Aucun créneau</p>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
)}
