---
import { env } from 'cloudflare:workers';
import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../lib/admin-auth';
import { getSmsConfig } from '../../lib/db/sms-config';

const authError = await requireAdmin(Astro.request, env);
if (authError) return Astro.redirect('/admin/login');

const smsConfig = await getSmsConfig(env.DB);
---
<AdminLayout title="Administration" active="home">
  <div class="max-w-4xl mx-auto px-4 py-6 space-y-6">

    <!-- Quick nav tiles -->
    <section class="grid grid-cols-2 gap-3 sm:grid-cols-4">
      <a href="/admin/practitioners" class="flex flex-col items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white rounded-xl px-4 py-5 text-center transition-colors shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 opacity-90"><path d="M4.5 6.375a4.125 4.125 0 1 1 8.25 0 4.125 4.125 0 0 1-8.25 0ZM14.25 8.625a3.375 3.375 0 1 1 6.75 0 3.375 3.375 0 0 1-6.75 0ZM1.5 19.125a7.125 7.125 0 0 1 14.25 0v.003l-.001.119a.75.75 0 0 1-.363.63 13.067 13.067 0 0 1-6.761 1.873c-2.472 0-4.786-.684-6.76-1.873a.75.75 0 0 1-.364-.63l-.001-.122ZM17.25 19.128l-.001.144a2.25 2.25 0 0 1-.233.96 10.088 10.088 0 0 0 5.06-1.01.75.75 0 0 0 .42-.643 4.875 4.875 0 0 0-6.957-4.611 8.586 8.586 0 0 1 1.71 5.157v.003Z"/></svg>
        <span class="text-sm font-semibold">Praticien·nes</span>
      </a>
      <a href="/admin/schedule" class="flex flex-col items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl px-4 py-5 text-center transition-colors shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 opacity-90"><path fill-rule="evenodd" d="M6.75 2.25A.75.75 0 0 1 7.5 3v1.5h9V3A.75.75 0 0 1 18 3v1.5h.75a3 3 0 0 1 3 3v11.25a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3V7.5a3 3 0 0 1 3-3H6V3a.75.75 0 0 1 .75-.75Zm13.5 9a1.5 1.5 0 0 0-1.5-1.5H5.25a1.5 1.5 0 0 0-1.5 1.5v7.5a1.5 1.5 0 0 0 1.5 1.5h13.5a1.5 1.5 0 0 0 1.5-1.5v-7.5Z" clip-rule="evenodd"/></svg>
        <span class="text-sm font-semibold">Planning</span>
      </a>
      <a href="/admin/bookings" class="flex flex-col items-center gap-2 bg-violet-600 hover:bg-violet-700 text-white rounded-xl px-4 py-5 text-center transition-colors shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 opacity-90"><path fill-rule="evenodd" d="M10.5 3.75a6.75 6.75 0 1 0 0 13.5 6.75 6.75 0 0 0 0-13.5ZM2.25 10.5a8.25 8.25 0 1 1 14.59 5.28l4.69 4.69a.75.75 0 1 1-1.06 1.06l-4.69-4.69A8.25 8.25 0 0 1 2.25 10.5Z" clip-rule="evenodd"/></svg>
        <span class="text-sm font-semibold">Réservations</span>
      </a>
      <a href="/admin/stats" class="flex flex-col items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl px-4 py-5 text-center transition-colors shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 opacity-90"><path d="M18.375 2.25c-1.035 0-1.875.84-1.875 1.875v15.75c0 1.035.84 1.875 1.875 1.875h.75c1.035 0 1.875-.84 1.875-1.875V4.125c0-1.036-.84-1.875-1.875-1.875h-.75ZM9.75 8.625c0-1.036.84-1.875 1.875-1.875h.75c1.036 0 1.875.84 1.875 1.875v11.25c0 1.035-.84 1.875-1.875 1.875h-.75a1.875 1.875 0 0 1-1.875-1.875V8.625ZM3 13.125c0-1.036.84-1.875 1.875-1.875h.75c1.036 0 1.875.84 1.875 1.875v6.75c0 1.035-.84 1.875-1.875 1.875h-.75A1.875 1.875 0 0 1 3 19.875v-6.75Z"/></svg>
        <span class="text-sm font-semibold">Statistiques</span>
      </a>
    </section>

    <!-- SMS Feature Flags -->
    <section class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
      <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">Notifications SMS</h2>
      <form id="sms-config-form" class="space-y-4">
        <label class="flex items-center justify-between cursor-pointer py-1">
          <span class="text-sm font-medium text-gray-800">Confirmation de réservation</span>
          <input
            type="checkbox"
            id="sms-confirmation"
            class="w-4 h-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500"
            checked={smsConfig.confirmation_enabled === 1}
          />
        </label>
        <div class="border-t border-gray-100"></div>
        <label class="flex items-center justify-between cursor-pointer py-1">
          <span class="text-sm font-medium text-gray-800">Rappel 5 min avant le créneau</span>
          <input
            type="checkbox"
            id="sms-reminder"
            class="w-4 h-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500"
            checked={smsConfig.reminder_enabled === 1}
          />
        </label>
        <div class="border-t border-gray-100"></div>
        <label class="flex items-center justify-between cursor-pointer py-1">
          <span class="text-sm font-medium text-gray-800">Notification praticien·ne (manuel)</span>
          <input
            type="checkbox"
            id="sms-trigger"
            class="w-4 h-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500"
            checked={smsConfig.practitioner_trigger_enabled === 1}
          />
        </label>
        <div class="flex items-center gap-3 pt-2">
          <button
            type="submit"
            class="bg-indigo-600 text-white text-sm px-5 py-2 rounded-lg hover:bg-indigo-700 font-medium transition-colors"
          >
            Enregistrer
          </button>
          <p id="sms-result" class="text-sm text-emerald-700 font-medium hidden">Enregistré.</p>
          <p id="sms-error" class="text-sm text-red-600 hidden"></p>
        </div>
      </form>
    </section>

    <!-- SMS test -->
    <section class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
      <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">Tester le relais SMS</h2>
      <p class="text-xs text-gray-500 mb-3">Envoie un SMS de test via le relais Android pour vérifier que la chaîne fonctionne.</p>
      <div class="flex gap-2">
        <input
          id="sms-test-phone"
          type="tel"
          placeholder="+33612345678"
          class="flex-1 border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
        />
        <button
          id="sms-test-btn"
          class="bg-indigo-600 text-white text-sm px-4 py-2.5 rounded-lg hover:bg-indigo-700 font-medium transition-colors shrink-0 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Envoyer
        </button>
      </div>
      <p id="sms-test-result" class="text-sm text-emerald-700 font-medium mt-2 hidden">SMS en attente d'envoi par le relais.</p>
      <p id="sms-test-error" class="text-sm text-red-600 mt-2 hidden"></p>
    </section>
  </div>

  <script>
    const form = document.getElementById('sms-config-form') as HTMLFormElement;
    const result = document.getElementById('sms-result') as HTMLParagraphElement;
    const errorEl = document.getElementById('sms-error') as HTMLParagraphElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      result.classList.add('hidden');
      errorEl.classList.add('hidden');

      const resp = await fetch('/api/admin/sms-config', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          confirmationEnabled: (document.getElementById('sms-confirmation') as HTMLInputElement).checked,
          reminderEnabled: (document.getElementById('sms-reminder') as HTMLInputElement).checked,
          practitionerTriggerEnabled: (document.getElementById('sms-trigger') as HTMLInputElement).checked,
        }),
      });

      if (resp.ok) {
        result.classList.remove('hidden');
        setTimeout(() => result.classList.add('hidden'), 3000);
      } else {
        const json = await resp.json() as { error?: { message: string } };
        errorEl.textContent = json.error?.message ?? 'Erreur lors de la sauvegarde.';
        errorEl.classList.remove('hidden');
      }
    });

    // ── SMS test ──────────────────────────────────────────────────────────────
    const testBtn = document.getElementById('sms-test-btn') as HTMLButtonElement;
    const testPhone = document.getElementById('sms-test-phone') as HTMLInputElement;
    const testResult = document.getElementById('sms-test-result')!;
    const testError = document.getElementById('sms-test-error')!;

    testBtn.addEventListener('click', async () => {
      testResult.classList.add('hidden');
      testError.classList.add('hidden');
      const phone = testPhone.value.trim();
      if (!phone) {
        testError.textContent = 'Veuillez saisir un numéro de téléphone.';
        testError.classList.remove('hidden');
        return;
      }
      testBtn.disabled = true;
      const resp = await fetch('/api/admin/sms-test', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone }),
      });
      testBtn.disabled = false;
      if (resp.ok) {
        testResult.classList.remove('hidden');
        testPhone.value = '';
        setTimeout(() => testResult.classList.add('hidden'), 5000);
      } else {
        const json = await resp.json() as { error?: { message: string } };
        testError.textContent = json.error?.message ?? 'Erreur lors de l\'envoi.';
        testError.classList.remove('hidden');
      }
    });
  </script>
</AdminLayout>
