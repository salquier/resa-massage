# resa-massage — Required Environment Variables
# Copy to .dev.vars for local development (wrangler dev reads .dev.vars)
# Set production values via: wrangler secret put VAR_NAME

# Admin interface password hash (bcrypt or argon2id hash — never store plaintext)
# Generate: node -e "const bcrypt = require('bcryptjs'); bcrypt.hash('yourpassword', 12).then(console.log)"
ADMIN_PASSWORD_HASH=

# Secret for admin session cookie HMAC-SHA256 signing (32+ random bytes, hex or base64)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=

# Cloudflare Turnstile site key (public — injected in HTML, safe to expose)
# https://dash.cloudflare.com → Turnstile → Add site
# For local dev use test key: 1x00000000000000000000AA
TURNSTILE_SITE_KEY=

# Cloudflare Turnstile secret key (private — server-side verification only)
# For local dev use test key: 1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=

# Shared secret for Android SMS relay Bearer token authentication
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ANDROID_API_SECRET=

# Public base URL of the deployed application (no trailing slash)
# Used in confirmation SMS to construct the booking access link
# Example: https://resa-massage.example.workers.dev
APP_URL=
